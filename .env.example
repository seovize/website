# Contact form → Resend transactional email
# Get an API key: Resend dashboard → API Keys
RESEND_API_KEY=

# Where lead notifications are delivered (your Zoho inbox)
CONTACT_TO_EMAIL=info@seovize.com

# The "from" address. MUST be on a domain verified in Resend (Domains → Add Domain),
# otherwise Resend rejects the send. For first tests you can use onboarding@resend.dev.
CONTACT_FROM_EMAIL=info@seovize.com
CONTACT_FROM_NAME=Seovize Website

# Optional: secondary delivery (CRM, Slack, Zapier). Leave blank to disable.
CONTACT_WEBHOOK_URL=

# Brevo → marketing/nurture only (contact sync, lists, automations).
# Get an API key: Brevo dashboard → SMTP & API → API Keys
BREVO_API_KEY=

# Brevo list ID leads are synced into (defaults to 4 — "Website Leads").
BREVO_LIST_ID=4
